# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legalbot

# ── Go API ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
ENV=production

# ── LLM (pick one provider) ────────────────────────────────────────────────
LLM_PROVIDER=gigachat

# GigaChat (Sberbank) — get from https://developers.sber.ru/portal/products/gigachat
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_MODEL=GigaChat-Pro

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Yandex
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# ── RAG service ────────────────────────────────────────────────────────────
# Protects POST /ingest — set any random string
INGEST_API_KEY=secret-ingest-key

# Embedding provider: gigachat (1024-dim) or yandex (256-dim)
EMBEDDING_PROVIDER=yandex

# ── Production deploy (used by docker-compose.prod.yml) ────────────────────
# Your GitHub username (used to pull images from GHCR)
GITHUB_REPOSITORY_OWNER=
