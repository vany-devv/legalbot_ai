2.\~\u1042\'3f \u1089\'3f\u1083\'3f\u1091\'3f\u1095\'3f\u1072\'3f\u1077\'3f, \u1082\'3f\u1086\'3f\u1075\'3f\u1076\'3f\u1072\'3f \u1086\'3f\u1090\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1086\'3f\u1087\'3f\u1086\'3f\u1083\'3f\u1091\'3f\u1095\'3f\u1072\'3f\u1090\'3f\u1077\'3f\u1083\'3f\u1100\'3f \u1103\'3f\u1074\'3f\u1083\'3f\u1103\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1086\'3f\u1076\'3f\u1085\'3f\u1086\'3f\u1074\'3f\u1088\'3f\u1077\'3f\u1084\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f \u1085\'3f\u1072\'3f\u1089\'3f\u1083\'3f\u1077\'3f\u1076\'3f\u1085\'3f\u1080\'3f\u1082\'3f\u1086\'3f\u1084\'3f, \u1077\'3f\u1075\'3f\u1086\'3f \u1087\'3f\u1088\'3f\u1072\'3f\u1074\'3f\u1086\'3f, \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1091\'3f\u1089\'3f\u1084\'3f\u1086\'3f\u1090\'3f\u1088\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1077\'3f \u1085\'3f\u1072\'3f\u1089\'3f\u1090\'3f\u1086\'3f\u1103\'3f\u1097\'3f\u1077\'3f\u1081\'3f \u1089\'3f\u1090\'3f\u1072\'3f\u1090\'3f\u1100\'3f\u1077\'3f\u1081\'3f, \u1085\'3f\u1077\'3f \u1079\'3f\u1072\'3f\u1074\'3f\u1080\'3f\u1089\'3f\u1080\'3f\u1090\'3f \u1086\'3f\u1090\'3f \u1077\'3f\u1075\'3f\u1086\'3f \u1087\'3f\u1088\'3f\u1072\'3f\u1074\'3f\u1072\'3f \u1087\'3f\u1088\'3f\u1080\'3f\u1085\'3f\u1103\'3f\u1090\'3f\u1100\'3f \u1085\'3f\u1072\'3f\u1089\'3f\u1083\'3f\u1077\'3f\u1076\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1086\'3f \u1080\'3f\u1083\'3f\u1080\'3f \u1086\'3f\u1090\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1072\'3f\u1090\'3f\u1100\'3f\u1089\'3f\u1103\'3f \u1086\'3f\u1090\'3f \u1085\'3f\u1077\'3f\u1075\'3f\u1086\'3f.}
\par \pard\plain \s18\sl276\slmult1\li180\ri0\lin180\rin0\fi0\sb0\sa142\cf1\dbch\af5\dbch\af5\afs27\loch\f5\fs27\qj\li90\ri90\lin90\rin90\fi675\sb90\sa90{\rtlch \ltrch
\~\~}
\par \pard\plain \s18\sl276\slmult1\li180\ri0\lin180\rin0\fi0\sb0\sa142\cf1\dbch\af5\dbch\af5\afs27\loch\f5\fs27\ql\li1890\ri90\lin1890\rin90\fi-1215\sb90\sa90{\b\rtlch \ltrch\loch
\u1057\'3f\u1090\'3f\u1072\'3f\u1090\'3f\u1100\'3f\u1103\'3f 1161. \u1055\'3f\u1088\'3f\u1080\'3f\u1088\'3f\u1072\'3f\u1097\'3f\u1077\'3f\u1085\'3f\u1080\'3f\u1077\'3f \u1085\'3f\u1072\'3f\u1089\'3f\u1083\'3f\u1077\'3f\u1076\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1076\'3f\u1086\'3f\u1083\'3f\u1077\'3f\u1081\'3f}
\par \pard\plain \s18\sl276\slmult1\li180\ri0\lin180\rin0\fi0\sb0\sa142\cf1\dbch\af5\dbch\af5\afs27\loch\f5\fs27\qj\li90\ri90\lin90\rin90\fi675\sb90\sa90{\rtlch \ltrch
