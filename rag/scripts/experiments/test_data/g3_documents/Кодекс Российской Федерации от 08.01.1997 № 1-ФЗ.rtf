2.\~\u1055\'3f\u1077\'3f\u1088\'3f\u1077\'3f\u1095\'3f\u1077\'3f\u1085\'3f\u1100\'3f \u1080\'3f \u1082\'3f\u1086\'3f\u1083\'3f\u1080\'3f\u1095\'3f\u1077\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1086\'3f \u1074\'3f\u1077\'3f\u1097\'3f\u1077\'3f\u1081\'3f \u1080\'3f \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1084\'3f\u1077\'3f\u1090\'3f\u1086\'3f\u1074\'3f, \u1082\'3f\u1086\'3f\u1090\'3f\u1086\'3f\u1088\'3f\u1099\'3f\u1077\'3f \u1086\'3f\u1089\'3f\u1091\'3f\u1078\'3f\u1076\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1084\'3f \u1074\'3f\u1086\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1083\'3f\u1091\'3f\u1078\'3f\u1072\'3f\u1097\'3f\u1080\'3f\u1084\'3f \u1088\'3f\u1072\'3f\u1079\'3f\u1088\'3f\u1077\'3f\u1096\'3f\u1072\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1080\'3f\u1084\'3f\u1077\'3f\u1090\'3f\u1100\'3f \u1087\'3f\u1088\'3f\u1080\'3f \u1089\'3f\u1077\'3f\u1073\'3f\u1077\'3f, \u1091\'3f\u1089\'3f\u1090\'3f\u1072\'3f\u1085\'3f\u1072\'3f\u1074\'3f\u1083\'3f\u1080\'3f\u1074\'3f\u1072\'3f\u1102\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1087\'3f\u1088\'3f\u1072\'3f\u1074\'3f\u1080\'3f\u1083\'3f\u1072\'3f\u1084\'3f\u1080\'3f \u1086\'3f\u1090\'3f\u1073\'3f\u1099\'3f\u1074\'3f\u1072\'3f\u1085\'3f\u1080\'3f\u1103\'3f \u1091\'3f\u1075\'3f\u1086\'3f\u1083\'3f\u1086\'3f\u1074\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1085\'3f\u1072\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1072\'3f\u1085\'3f\u1080\'3f\u1081\'3f \u1086\'3f\u1089\'3f\u1091\'3f\u1078\'3f\u1076\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1084\'3f\u1080\'3f \u1074\'3f\u1086\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1083\'3f\u1091\'3f\u1078\'3f\u1072\'3f\u1097\'3f\u1080\'3f\u1084\'3f\u1080\'3f. \u1061\'3f\u1088\'3f\u1072\'3f\u1085\'3f\u1077\'3f\u1085\'3f\u1080\'3f\u1077\'3f \u1086\'3f\u1089\'3f\u1091\'3f\u1078\'3f\u1076\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1084\'3f\u1080\'3f \u1074\'3f\u1086\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1083\'3f\u1091\'3f\u1078\'3f\u1072\'3f\u1097\'3f\u1080\'3f\u1084\'3f\u1080\'3f \u1087\'3f\u1088\'3f\u1080\'3f \u1089\'3f\u1077\'3f\u1073\'3f\u1077\'3f \u1076\'3f\u1077\'3f\u1085\'3f\u1077\'3f\u1075\'3f, \u1094\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1073\'3f\u1091\'3f\u1084\'3f\u1072\'3f\u1075\'3f \u1080\'3f \u1080\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1094\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1090\'3f\u1077\'3f\u1081\'3f, \u1072\'3f \u1090\'3f\u1072\'3f\u1082\'3f\u1078\'3f\u1077\'3f \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1084\'3f\u1077\'3f\u1090\'3f\u1086\'3f\u1074\'3f, \u1085\'3f\u1077\'3f \u1091\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1072\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1074\'3f \u1087\'3f\u1077\'3f\u1088\'3f\u1077\'3f\u1095\'3f\u1085\'3f\u1077\'3f, \u1085\'3f\u1077\'3f \u1076\'3f\u1086\'3f\u1087\'3f\u1091\'3f\u1089\'3f\u1082\'3f\u1072\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1103\'3f.}
\par \pard\plain \s18\sl276\slmult1\li180\ri0\lin180\rin0\fi0\sb0\sa142\cf1\dbch\af5\dbch\af5\afs27\loch\f5\fs27\qj\li90\ri90\lin90\rin90\fi675\sb90\sa90{\rtlch \ltrch\loch
3.\~\u1054\'3f\u1073\'3f\u1085\'3f\u1072\'3f\u1088\'3f\u1091\'3f\u1078\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1077\'3f \u1091\'3f \u1086\'3f\u1089\'3f\u1091\'3f\u1078\'3f\u1076\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1074\'3f\u1086\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1083\'3f\u1091\'3f\u1078\'3f\u1072\'3f\u1097\'3f\u1080\'3f\u1093\'3f \u1076\'3f\u1077\'3f\u1085\'3f\u1100\'3f\u1075\'3f\u1080\'3f, \u1094\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1077\'3f \u1073\'3f\u1091\'3f\u1084\'3f\u1072\'3f\u1075\'3f\u1080\'3f \u1080\'3f \u1080\'3f\u1085\'3f\u1099\'3f\u1077\'3f \u1094\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1090\'3f\u1080\'3f \u1080\'3f\u1079\'3f\u1099\'3f\u1084\'3f\u1072\'3f\u1102\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1080\'3f \u1093\'3f\u1088\'3f\u1072\'3f\u1085\'3f\u1103\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1074\'3f \u1089\'3f\u1086\'3f\u1086\'3f\u1090\'3f\u1074\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1080\'3f\u1080\'3f \u1089\'3f \u1091\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1072\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1084\'3f\u1080\'3f \u1087\'3f\u1088\'3f\u1072\'3f\u1074\'3f\u1080\'3f\u1083\'3f\u1072\'3f\u1084\'3f\u1080\'3f \u1076\'3f\u1086\'3f \u1086\'3f\u1090\'3f\u1073\'3f\u1099\'3f\u1090\'3f\u1080\'3f\u1103\'3f \u1089\'3f\u1088\'3f\u1086\'3f\u1082\'3f\u1072\'3f \u1085\'3f\u1072\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1072\'3f\u1085\'3f\u1080\'3f\u1103\'3f. \u1047\'3f\u1072\'3f\u1087\'3f\u1088\'3f\u1077\'3f\u1097\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1077\'3f \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1084\'3f\u1077\'3f\u1090\'3f\u1099\'3f \u1080\'3f \u1074\'3f\u1077\'3f\u1097\'3f\u1077\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1072\'3f, \u1080\'3f\u1079\'3f\u1098\'3f\u1103\'3f\u1090\'3f\u1099\'3f\u1077\'3f \u1091\'3f \u1086\'3f\u1089\'3f\u1091\'3f\u1078\'3f\u1076\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1074\'3f\u1086\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1089\'3f\u1083\'3f\u1091\'3f\u1078\'3f\u1072\'3f\u1097\'3f\u1080\'3f\u1093\'3f, \u1087\'3f\u1077\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1072\'3f\u1102\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1085\'3f\u1072\'3f \u1093\'3f\u1088\'3f\u1072\'3f\u1085\'3f\u1077\'3f\u1085\'3f\u1080\'3f\u1077\'3f \u1083\'3f\u1080\'3f\u1073\'3f\u1086\'3f \u1091\'3f\u1085\'3f\u1080\'3f\u1095\'3f\u1090\'3f\u1086\'3f\u1078\'3f\u1072\'3f\u1102\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1087\'3f\u1086\'3f \u1087\'3f\u1088\'3f\u1080\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1091\'3f \u1082\'3f\u1086\'3f\u1084\'3f\u1072\'3f\u1085\'3f\u1076\'3f\u1080\'3f\u1088\'3f\u1072\'3f \u1076\'3f\u1080\'3f\u1089\'3f\u1094\'3f\u1080\'3f\u1087\'3f\u1083\'3f\u1080\'3f\u1085\'3f\u1072\'3f\u1088\'3f\u1085\'3f\u1086\'3f\u1081\'3f \u1074\'3f\u1086\'3f\u1080\'3f\u1085\'3f\u1089\'3f\u1082\'3f\u1086\'3f\u1081\'3f \u1095\'3f\u1072\'3f\u1089\'3f\u1090\'3f\u1080\'3f, \u1086\'3f \u1095\'3f\u1077\'3f\u1084\'3f \u1089\'3f\u1086\'3f\u1089\'3f\u1090\'3f\u1072\'3f\u1074\'3f\u1083\'3f\u1103\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1089\'3f\u1086\'3f\u1086\'3f\u1090\'3f\u1074\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1091\'3f\u1102\'3f\u1097\'3f\u1080\'3f\u1081\'3f \u1072\'3f\u1082\'3f\u1090\'3f.}
